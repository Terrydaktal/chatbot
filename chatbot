#!/bin/bash
# run-chatbot.sh - Helper to launch Chromium securely and start the chatbot

CHROMIUM_BIN="/bin/chromium"
PORT="${PORT:-9233}"
VERSION="1.0.9"

# Resolve script directory (handling symlinks)
SOURCE="${BASH_SOURCE[0]}"
while [ -h "$SOURCE" ]; do # resolve $SOURCE until the file is no longer a symlink
  DIR="$( cd -P "$( dirname "$SOURCE" )" >/dev/null 2>&1 && pwd )"
  SOURCE="$(readlink "$SOURCE")"
  [[ $SOURCE != /* ]] && SOURCE="$DIR/$SOURCE" # if $SOURCE was a relative symlink, we need to resolve it relative to the path where the symlink file was located
done
SCRIPT_DIR="$( cd -P "$( dirname "$SOURCE" )" >/dev/null 2>&1 && pwd )"

# Fast path for version queries: do not launch Chromium.
for arg in "$@"; do
  if [ "$arg" == "--version" ] || [ "$arg" == "-V" ]; then
    echo "$VERSION"
    exit 0
  fi
done

# Parse wrapper flags and keep remaining args for chatbot.js
RELOAD=0
VIRTUAL=0
FORWARD_ARGS=()
for arg in "$@"; do
  case "$arg" in
    --reload)
      RELOAD=1
      FORWARD_ARGS+=("$arg")
      ;;
    --virtual)
      VIRTUAL=1
      ;;
    *)
      FORWARD_ARGS+=("$arg")
      ;;
  esac
done

# Handle reload: Kill existing process if requested
if [ $RELOAD -eq 1 ]; then
    echo "Reload requested. Checking for existing browser..."
    # Find PID listening on the port
    PID=$(lsof -t -i:$PORT -sTCP:LISTEN)
    if [ ! -z "$PID" ]; then
        echo "Killing existing browser process $PID..."
        kill $PID
        # Wait for it to exit
        while kill -0 $PID 2>/dev/null; do sleep 0.5; done
        echo "Browser closed."
    fi
    # Reset RELOAD flag to 0 so we fall through to the launch logic below
    RELOAD=0
fi

# Check if port is already in use (It shouldn't be if we just reloaded, or if it wasn't running)
if ! lsof -i:$PORT -sTCP:LISTEN > /dev/null; then
    if [ $VIRTUAL -eq 1 ]; then
        if ! command -v xvfb-run > /dev/null 2>&1; then
            echo "Error: --virtual requires xvfb-run (Xvfb)."
            exit 1
        fi
        echo "Launching Chromium in a virtual X display on port $PORT..."
        # Launch inside an isolated Xvfb display so no desktop window is focused.
        setsid xvfb-run -a --server-args="-screen 0 1920x1080x24 -nolisten tcp" \
            $CHROMIUM_BIN \
            --user-data-dir=/home/lewis/.config/chromium-chatbot \
            --remote-debugging-port=$PORT \
            --start-minimized \
            --no-first-run \
            --no-default-browser-check \
            --disable-background-timer-throttling \
            --disable-renderer-backgrounding \
            --disable-backgrounding-occluded-windows \
            --disable-features=CalculateNativeWinOcclusion \
            > /dev/null 2>&1 &
    else
        echo "Launching Chromium with chromium-chatbot profile on port $PORT..."
        
        # Ensure environment is set for X11 (essential for SSH usage)
        export DISPLAY="${DISPLAY:-:0}"
        export XAUTHORITY="${XAUTHORITY:-$HOME/.Xauthority}"

        # Flags prevent background throttling when the window is minimized/occluded.
        # Use setsid to run in a new session, completely detaching from the terminal's process group.
        setsid $CHROMIUM_BIN \
            --user-data-dir=/home/lewis/.config/chromium-chatbot \
            --remote-debugging-port=$PORT \
            --start-minimized \
            --no-first-run \
            --no-default-browser-check \
            --disable-background-timer-throttling \
            --disable-renderer-backgrounding \
            --disable-backgrounding-occluded-windows \
            --disable-features=CalculateNativeWinOcclusion \
            > /dev/null 2>&1 &
    fi
    
    # Save PID for chatbot.js to manage
    echo $! > "$SCRIPT_DIR/.chatbot-pid"
    
    echo "Waiting for Chromium to initialize..."
    sleep 2
else
    echo "Chromium is already running on port $PORT."
fi

echo "Starting Chatbot..."
CHATBOT_VERSION="$VERSION" "$SCRIPT_DIR/chatbot.js" --port $PORT "${FORWARD_ARGS[@]}"
